  "keyFeatures": [
    "FHIR R4 compliant APIs for healthcare data exchange",
    "Role-based access control with admin, practitioner, and auditor roles",
    "AES-256-GCM encryption for PHI data at rest",
    "Patient self-registration portal with automatic PID assignment",
    "Comprehensive scheduling system with conflict detection",
    "Clinical command center for risk stratification and care gaps",
    "Audit logging for all FHIR and admin operations",
    "Care-team task management with assignment workflow"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
